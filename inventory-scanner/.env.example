# Core
PORT=3000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=your_key_here

# YouTube Data API (free — get at console.cloud.google.com)
YOUTUBE_API_KEY=your_key_here

# SerpAPI for Google Search Ad monitoring (free tier: 100/month)
SERPAPI_KEY=your_key_here

# Optional: ScraperAPI for Meta fallback (free tier: 1000 credits)
SCRAPER_API_KEY=your_key_here

# Meta Ad Library (no key needed for basic access)
META_AD_LIBRARY_BASE_URL=https://www.facebook.com/ads/library/api/

# Rate limiting
META_SCRAPE_DELAY_MS=3000
GOOGLE_SCRAPE_DELAY_MS=2000
MAX_CONCURRENT_REQUESTS=3
